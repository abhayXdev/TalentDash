generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Level {
  ENTRY
  MID
  SENIOR
  STAFF
  PRINCIPAL
}

enum Currency {
  USD
  EUR
  GBP
  INR
  CAD
}

enum Source {
  VERIFIED
  UNVERIFIED
  EXTERNAL
}

model Company {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  normalized_name String
  industry        String?
  headquarters    String?
  founded_year    Int?
  headcount_range String?
  
  salaries        Salary[]
  
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}

model Salary {
  id                 String    @id @default(cuid())
  role               String
  level              Level
  location           String
  currency           Currency  @default(USD)
  experience_years   Float
  base_salary        Int
  bonus              Int       @default(0)
  stock              Int       @default(0)
  total_compensation Int
  source             Source    @default(UNVERIFIED)
  confidence_score   Float     @default(0)
  is_verified        Boolean   @default(false)
  
  company_id         String
  company            Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  
  submitted_at       DateTime  @default(now())

  @@index([company_id, level, location])
  @@index([total_compensation])
  @@index([submitted_at])
  @@index([location, level])
}
